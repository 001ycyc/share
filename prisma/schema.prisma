// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// User
// ============================================================
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  displayName  String
  avatarUrl    String?
  storageUsed  BigInt    @default(0)
  storageLimit BigInt    @default(1073741824)
  plan         String    @default("free")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clips     Clip[]
  devices   Device[]
  syncLogs  SyncLog[]
  backups   Backup[]

  @@map("users")
}

// ============================================================
// Clip
// ============================================================
model Clip {
  id             String   @id @default(uuid())
  userId         String
  type           String
  title          String
  content        String
  contentPreview String
  fileUrl        String?
  fileSize       BigInt?
  mimeType       String?
  metadata       Json?
  sourceDevice   String   @default("web")
  isFavorite     Boolean  @default(false)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncLogs  SyncLog[]

  @@index([userId, isDeleted, createdAt])
  @@index([userId, type])
  @@index([userId, isFavorite])
  @@map("clips")
}

// ============================================================
// Device
// ============================================================
model Device {
  id                 String    @id @default(uuid())
  userId             String
  name               String
  platform           String
  deviceFingerprint  String    @unique
  lastSyncAt         DateTime?
  isOnline           Boolean   @default(false)
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devices")
}

// ============================================================
// SyncLog
// ============================================================
model SyncLog {
  id         String   @id @default(uuid())
  userId     String
  clipId     String?
  fromDevice String
  toDevice   String
  action     String
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clip Clip?  @relation(fields: [clipId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("sync_logs")
}

// ============================================================
// Backup
// ============================================================
model Backup {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("manual")
  fileUrl   String
  fileSize  BigInt   @default(0)
  clipCount Int      @default(0)
  status    String   @default("creating")
  checksum  String   @default("")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("backups")
}

// ============================================================
// ErrorCode
// ============================================================
model ErrorCode {
  id          String   @id @default(uuid())
  code        String   @unique
  category    String
  name        String
  description String   @default("")
  userMessage String
  severity    String   @default("error")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("error_codes")
}

// ============================================================
// StorageCleanupLog
// ============================================================
model StorageCleanupLog {
  id             String    @id @default(uuid())
  taskType       String
  itemsProcessed Int       @default(0)
  spaceFreed     BigInt    @default(0)
  status         String    @default("running")
  errorDetail    String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@map("storage_cleanup_logs")
}
